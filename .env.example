# ── Supabase ────────────────────────────────────────────────────────────────
# URL e anon key do projeto (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — APENAS server-side. Nunca exponha com prefixo NEXT_PUBLIC_.
# Usada para: leitura do schema `perseo`, convites de usuário, captura de lead.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ─────────────────────────────────────────────────────────────────────
# URL pública do app (Railway). Usada em redirects de auth (convite/OAuth).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
